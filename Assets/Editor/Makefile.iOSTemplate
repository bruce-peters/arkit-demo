	-I$(IL2CPP_DIR)/libil2cpp/icalls_monoaot/System.Private.CoreLib/System \
	-I$(IL2CPP_DIR)/libil2cpp/icalls_monoaot/System.Private.CoreLib/System.Diagnostics \
	-I$(IL2CPP_DIR)/libil2cpp/icalls_monoaot/System.Private.CoreLib/System.Diagnostics.Tracing \
	-I$(IL2CPP_DIR)/libil2cpp/icalls_monoaot/System.Private.CoreLib/System.IO \
	-I$(IL2CPP_DIR)/libil2cpp/icalls_monoaot/System.Private.CoreLib/System.Reflection \
	-I$(IL2CPP_DIR)/libil2cpp/icalls_monoaot/System.Private.CoreLib/System.Reflection.Emit \
	-I$(IL2CPP_DIR)/libil2cpp/icalls_monoaot/System.Private.CoreLib/System.Reflection.Metadata \
	-I$(IL2CPP_DIR)/libil2cpp/icalls_monoaot/System.Private.CoreLib/System.Runtime.CompilerServices \
	-I$(IL2CPP_DIR)/libil2cpp/icalls_monoaot/System.Private.CoreLib/System.Runtime.InteropServices \
	-I$(IL2CPP_DIR)/libil2cpp/icalls_monoaot/System.Private.CoreLib/System.Runtime.Intrinsics.X86 \
