	-I$(IL2CPP_DIR)/libil2cpp/intrinsics \
	-I$(IL2CPP_DIR)/libil2cpp/intrinsics/System.Private.CoreLib/Interop \
	-I$(IL2CPP_DIR)/libil2cpp/intrinsics/System.Private.CoreLib/System \
	-I$(IL2CPP_DIR)/libil2cpp/intrinsics/System.Private.CoreLib/System/Diagnostics \
	-I$(IL2CPP_DIR)/libil2cpp/intrinsics/System.Private.CoreLib/System/Diagnostics/Tracing \
	-I$(IL2CPP_DIR)/libil2cpp/intrinsics/System.Private.CoreLib/System/Numerics \
	-I$(IL2CPP_DIR)/libil2cpp/intrinsics/System.Private.CoreLib/System/Reflection \
	-I$(IL2CPP_DIR)/libil2cpp/intrinsics/System.Private.CoreLib/System/Runtime \
	-I$(IL2CPP_DIR)/libil2cpp/intrinsics/System.Private.CoreLib/System/Runtime/CompilerServices \
	-I$(IL2CPP_DIR)/libil2cpp/intrinsics/System.Private.CoreLib/System/Runtime/InteropServices \
	-I$(IL2CPP_DIR)/libil2cpp/intrinsics/System.Private.CoreLib/System/Runtime/Intrinsics \
	-I$(IL2CPP_DIR)/libil2cpp/intrinsics/System.Private.CoreLib/System/Threading \
	-I$(IL2CPP_DIR)/libil2cpp/intrinsics/UnityEngine.CoreModule/Unity/Collections \
	-I$(IL2CPP_DIR)/libil2cpp/intrinsics/UnityEngine.CoreModule/Unity/Collections/LowLevel/Unsafe \
	-I$(IL2CPP_DIR)/libil2cpp/intrinsics/UnityEngine.CoreModule/UnityEngine \
	-I$(IL2CPP_DIR)/libil2cpp/metadata \
	-I$(IL2CPP_DIR)/libil2cpp/mono \
	-I$(IL2CPP_DIR)/libil2cpp/mono/ThreadPool \
