	-I$(IL2CPP_DIR)/libil2cpp/os/ClassLibraryPAL/brotli/common \
	-I$(IL2CPP_DIR)/libil2cpp/os/ClassLibraryPAL/brotli/dec \
	-I$(IL2CPP_DIR)/libil2cpp/os/ClassLibraryPAL/brotli/enc \
	-I$(IL2CPP_DIR)/libil2cpp/os/ClassLibraryPAL/brotli/include/brotli \
	-I$(IL2CPP_DIR)/libil2cpp/os/Emscripten \
	-I$(IL2CPP_DIR)/libil2cpp/os/Generic \
	-I$(IL2CPP_DIR)/libil2cpp/os/Linux \
	-I$(IL2CPP_DIR)/libil2cpp/os/OSX \
	-I$(IL2CPP_DIR)/libil2cpp/os/Posix \
	-I$(IL2CPP_DIR)/libil2cpp/os/Std \
	-I$(IL2CPP_DIR)/libil2cpp/os/Win32 \
	-I$(IL2CPP_DIR)/libil2cpp/os/WindowsGames \
	-I$(IL2CPP_DIR)/libil2cpp/os/WinRT \
	-I$(IL2CPP_DIR)/libil2cpp/utils \
	-I$(IL2CPP_DIR)/libil2cpp/vm \
	-I$(IL2CPP_DIR)/libil2cpp/vm-utils \
	-I$(IL2CPP_DIR)/libmono \
	-I$(IL2CPP_DIR)/libmono/config \
	-I$(IL2CPP_DIR)/external \
	-I$(IL2CPP_DIR)/external/baselib/Include \
	-I$(IL2CPP_DIR)/external/baselib/Include/C \
	-I$(IL2CPP_DIR)/external/baselib/Include/C/Internal \
	-I$(IL2CPP_DIR)/external/baselib/Include/C/Internal/Compiler \
	-I$(IL2CPP_DIR)/external/baselib/Include/Cpp \
	-I$(IL2CPP_DIR)/external/baselib/Include/Cpp/Internal \
	-I$(IL2CPP_DIR)/external/baselib/Include/Cpp/Internal/Compiler/ClangOrGcc \
	-I$(IL2CPP_DIR)/external/baselib/Include/Internal \
	-I$(IL2CPP_DIR)/external/baselib/Include/Internal/Compiler \
	-I$(IL2CPP_DIR)/external/baselib/Include/External/utfcpp/source \
	-I$(IL2CPP_DIR)/external/baselib/Include/External/utfcpp/source/utf8 \
	-I$(IL2CPP_DIR)/external/baselib/Platforms/IOS/Include \
	-I$(IL2CPP_DIR)/external/baselib/Platforms/IOS/Include/C \
	-I$(IL2CPP_DIR)/external/baselib/Platforms/OSX/Include \
	-I$(IL2CPP_DIR)/external/baselib/Platforms/OSX/Include/C \
	-I$(IL2CPP_DIR)/external/bdwgc/include \
	-I$(IL2CPP_DIR)/external/bdwgc/include/extra \
	-I$(IL2CPP_DIR)/external/bdwgc/include/private \
	-I$(IL2CPP_DIR)/external/bdwgc/libatomic_ops/src \
	-I$(IL2CPP_DIR)/external/bdwgc/libatomic_ops/src/atomic_ops \
	-I$(IL2CPP_DIR)/external/bdwgc/libatomic_ops/src/atomic_ops/sysdeps/gcc \
	-I$(IL2CPP_DIR)/external/bdwgc/libatomic_ops/src/atomic_ops/sysdeps/loadstore \
	-I$(IL2CPP_DIR)/external/google/sparsehash \
	-I$(IL2CPP_DIR)/external/google/sparsehash/internal \
	-I$(IL2CPP_DIR)/external/mono/mono/eglib \
	-I$(IL2CPP_DIR)/external/mono/mono/metadata \
	-I$(IL2CPP_DIR)/external/mono/mono/utils \
	-I$(IL2CPP_DIR)/external/xxHash \
	-I$(IL2CPP_DIR)/external/zlib-unity \
	-I$(IL2CPP_DIR)/external/xamarin-android \
	-I$(LIB_DIR) \
	-I$(LIB_DIR)/baselib/Include \
	-I$(LIB_DIR)/baselib/Include/C \
	-I$(LIB_DIR)/baselib/Include/Cpp

CFLAGS := -arch arm64 -isysroot $(SDK_PATH) -miphoneos-version-min=12.0 \
	-std=c++17 -stdlib=libc++ -fno-exceptions -fno-rtti \
	-O2 -DNDEBUG -DIL2CPP_ENABLE_WRITE_BARRIERS=1 \
	-fcolor-diagnostics \
	$(INCLUDES)

.PHONY: all clean

all: $(TARGET)

$(OBJ_DIR):
	mkdir -p $(OBJ_DIR)

$(TARGET): $(OBJ_DIR) $(OBJECTS)
	ar rcs $@ $(OBJECTS)
	@echo "Built $@ ($(words $(OBJECTS)) objects)"

$(OBJ_DIR)/%.o: $(SRC_DIR)/%.cpp
	$(CLANG) $(CFLAGS) -c $< -o $@