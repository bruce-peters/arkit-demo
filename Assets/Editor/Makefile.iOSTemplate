	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/System.IO \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/System.Reflection \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/System.Runtime \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/System.Runtime.CompilerServices \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/System.Runtime.InteropServices \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/System.Runtime.Remoting \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/System.Runtime.Remoting.Activation \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/System.Runtime.Remoting.Contexts \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/System.Runtime.Remoting.Messaging \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/System.Runtime.Remoting.Proxies \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/System.Runtime.Versioning \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/System.Security.Cryptography \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/System.Security.Policy \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/System.Security.Principal \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/System.Text \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/System.Threading \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/System \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/System/Microsoft.Win32 \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/System/Mono.Net.Security \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/System/System.Diagnostics \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/System/System.IO \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/System/System.Net \
