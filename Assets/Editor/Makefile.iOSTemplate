# Generated Makefile - compiles IL2CPP C++ using Xcode's native clang++
SHELL := /bin/bash
XCODE_DEVELOPER := $(shell xcode-select -p)
SDK_PATH := $(shell xcrun --sdk iphoneos --show-sdk-path)
CLANG := $(XCODE_DEVELOPER)/Toolchains/XcodeDefault.xctoolchain/usr/bin/clang++

SRC_DIR := Il2CppOutputProject/Source/il2cppOutput
OBJ_DIR := Il2CppTempDirArtifacts/Release/objs
TARGET := $(CONFIGURATION_BUILD_DIR)/libGameAssembly.a
LIB_DIR := Libraries
IL2CPP_DIR := Il2CppOutputProject/IL2CPP

SOURCES := $(wildcard $(SRC_DIR)/*.cpp)
OBJECTS := $(patsubst $(SRC_DIR)/%.cpp,$(OBJ_DIR)/%.o,$(SOURCES))

INCLUDES := \
	-I$(SRC_DIR) \
	-I$(IL2CPP_DIR)/libil2cpp \
	-I$(IL2CPP_DIR)/libil2cpp/pch \
	-I$(IL2CPP_DIR)/libil2cpp/codegen \
	-I$(IL2CPP_DIR)/libil2cpp/debugger \
	-I$(IL2CPP_DIR)/libil2cpp/gc \
	-I$(IL2CPP_DIR)/libil2cpp/icalls \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/Microsoft.Win32 \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/Mono \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/Mono.Security.Cryptography \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/Mono.Unity \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/System \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/System.Diagnostics \
	-I$(IL2CPP_DIR)/libil2cpp/icalls/mscorlib/System.Globalization \
